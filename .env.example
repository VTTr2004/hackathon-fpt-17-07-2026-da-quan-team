POSTGRES_DB=startup_due_diligence
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5433/startup_due_diligence
AUTO_CREATE_TABLES=true
# Tự tạo tài khoản và hồ sơ demo khi backend khởi động (idempotent).
SEED_SAMPLE_DATA=false
SAMPLE_DATA_PASSWORD=Demo1234!
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_HOURS=24
# RAG chatbot LLM provider: "gemini" (default) or "nvidia". Both are supported.
LLM_PROVIDER=gemini
# Gemini (analyzers + RAG generation/embeddings). One key, or several comma-separated for failover.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_OCR_MODEL=gemini-3.1-flash-lite
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_TIMEOUT_SECONDS=60
# NVIDIA NIM (used for RAG when LLM_PROVIDER=nvidia)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=openai/gpt-oss-120b
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_TIMEOUT_SECONDS=60
# Retrieval knobs (see backend/app/modules/document_chatbot/docs/methodology.md)
RAG_TOP_K=5
RAG_CANDIDATE_K=10
RAG_USE_RERANK=false
# Surrounding-area / maps providers
GOONG_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
