POSTGRES_DB=startup_due_diligence
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5433/startup_due_diligence
AUTO_CREATE_TABLES=true
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
# Một key hoặc nhiều key theo thứ tự failover, phân tách bằng dấu phẩy.
GEMINI_API_KEY=api1,api2,api3
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60
GOONG_API_KEY=
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
